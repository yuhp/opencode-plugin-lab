{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-models-discovery@latest",
    [
      "file:/./",
      {
        "enableConfigMutation": true,
        "injectShellEnv": true,
        "enableLabTool": true,
        "enableProviderHook": true,
        "debug": true,
        "tag": "lab",
        "writeLocalLog": true,
        "clearLocalLog": true
      }
    ]
  ],
  "provider": {}
}